# ─────────────────────────────────────────────────────────────
# Studio Bei OS — Environment Variables
#
# 本地开发：复制为 .env.local（被 dotenv-cli + Next.js 读取）
# 生产部署（ECS docker compose）：复制为 .env（被 docker compose 读取）
# 注意：.env / .env.local 永远不要 commit
#
# 标签速查：
#   🔴 必填      — 不配跑不起来 / 部署直接失败
#   🟡 强烈推荐  — 不配的话核心功能不可用（如登录、Feishu 通知）
#   ⚪ 可跳      — 不配走 fallback，本轮可推迟到 Day-2
# ─────────────────────────────────────────────────────────────


# ═════════════════ 🔴 必填 ═════════════════

# === 站点基础 ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# === 数据库 ===
# 本地开发：用 docker 起一个 postgres 即可，例如：
#   docker run -d --name pg -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:17-alpine
#   DATABASE_URL="postgres://postgres:dev@localhost:5432/postgres"
# 生产（docker compose）：仅需要填 POSTGRES_PASSWORD，docker-compose.yml 自动拼出 URL
DATABASE_URL="postgres://postgres:dev@localhost:5432/postgres"
# 生产强密码：openssl rand -hex 16
POSTGRES_PASSWORD=""

# === Better Auth ===
# openssl rand -hex 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# === 初始管理员（仅 db:seed 时使用，首次部署必填一次） ===
ADMIN_EMAIL="you@example.com"
# 应急通道用，可留空走飞书 SSO
ADMIN_INITIAL_PASSWORD=""
# 预绑定的飞书 OpenID（让 SSO 首次登录自动认为这是 admin）
ADMIN_LARK_OPEN_ID=""


# ═════════════════ 🟡 强烈推荐 ═════════════════

# === 飞书开放平台（企业自建应用） ===
# 不配 → 无飞书登录 SSO + 无飞书卡片通知；前端登录页只能用密码
FEISHU_APP_ID="cli_xxxxxxxxx"
FEISHU_APP_SECRET=""
# 卡片回调验签：生产强制要求，不配生产环境 /api/feishu/callback 直接 401
FEISHU_VERIFICATION_TOKEN=""
FEISHU_REDIRECT_URI="http://localhost:3000/api/auth/callback/feishu"

# === 定时任务鉴权（飞书日报/周报 cron） ===
# /api/cron/briefing/{daily|weekly} 要求 Authorization: Bearer ${CRON_SECRET}
# 生成：openssl rand -hex 32
# 不配 → 这两个 cron 接口任何人能调（影响小，但不推荐）
CRON_SECRET=""


# ═════════════════ ⚪ 可跳（Day-2 再配） ═════════════════

# === 飞书加密回调（仅当你在飞书后台勾选了"加密"才需要） ===
# 飞书后台 → 事件订阅 → 安全设置 → 加密推送 = 关闭时留空
FEISHU_ENCRYPT_KEY=""

# === Vercel Blob（M9 cases 模块的图片上传才用） ===
# 不配 → cases 不能上传新图（旧图正常显示）
BLOB_READ_WRITE_TOKEN=""

# === 限流（Upstash Redis） ===
# 不配 → 自动 fallback 到进程内内存
# 单实例部署：留空完全 OK
# 多实例 / 多区域：必须配，否则计数器跨实例不共享
# 注册：https://console.upstash.com/redis → 建 DB → 复制 REST URL + Token
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# === Sentry 错误监控 ===
# 不配 → 整个 Sentry 集成 no-op，错误只能 docker logs 看
# 注册：https://sentry.io/signup 免费版 5k events/月
# NEXT_PUBLIC_* 必须在 docker compose build 之前可见（内联进 client bundle）
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# 仅构建期 source map 上传用；GitHub Actions 里走 secrets.SENTRY_AUTH_TOKEN
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# === DB 备份 — 三档自适应（详见 docs/backup.md） ===
# 模式 A · 啥都不配 → 本地裸 gzip 到 /var/backups/studio-bei/（默认、零配置）
# 模式 B · 仅配 BACKUP_ENCRYPT_PASSPHRASE → 本地加密
# 模式 C · 上面 + BACKUP_OSS_BUCKET/ENDPOINT → 加密 + OSS 异地副本
#
# 加密口令（务必另存到密码管理器；丢了 = 加密备份永远解不开）
# 生成：openssl rand -base64 48
BACKUP_ENCRYPT_PASSPHRASE=""
# OSS bucket 名（先建 bucket + 配 RAM + 加 7 天 lifecycle 规则，见 docs/backup.md C-1/C-2）
BACKUP_OSS_BUCKET=""
# 同区内网 endpoint 免流量费：oss-cn-shanghai-internal.aliyuncs.com
# 跨区或公网：oss-cn-shanghai.aliyuncs.com
BACKUP_OSS_ENDPOINT="oss-cn-shanghai-internal.aliyuncs.com"
# 可选：OSS 内对象路径前缀（默认 studio-bei-os/）
# BACKUP_OSS_PREFIX="studio-bei-os/"
# 可选：本地保存目录（默认 /var/backups/studio-bei）和本地保留天数（默认 7）
# BACKUP_LOCAL_DIR="/var/backups/studio-bei"
# BACKUP_LOCAL_KEEP_DAYS="7"
