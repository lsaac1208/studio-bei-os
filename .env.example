# ─────────────────────────────────────────────────────────────
# Studio Bei OS — Environment Variables
# 本地开发：复制为 .env.local（被 dotenv-cli + Next.js 读取）
# 生产部署（ECS docker compose）：复制为 .env （被 docker compose 读取）
# 注意：.env / .env.local 永远不要 commit
# ─────────────────────────────────────────────────────────────

# === 站点基础 ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# === 数据库 ===
# 本地开发：用 docker 起一个 postgres 即可，例如：
#   docker run -d --name pg -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:17-alpine
#   DATABASE_URL="postgres://postgres:dev@localhost:5432/postgres"
# 生产（docker compose）：仅需要填 POSTGRES_PASSWORD，docker-compose.yml 自动拼
DATABASE_URL="postgres://postgres:dev@localhost:5432/postgres"
# 生产环境用强密码 (openssl rand -hex 16)
POSTGRES_PASSWORD=""

# === Better Auth ===
# openssl rand -hex 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# === 初始管理员（仅 db:seed 时使用） ===
ADMIN_EMAIL="you@example.com"
# 可为空；仅应急通道使用
ADMIN_INITIAL_PASSWORD=""
# 预绑定的飞书 OpenID
ADMIN_LARK_OPEN_ID=""

# === 飞书开放平台（企业自建应用） ===
FEISHU_APP_ID="cli_xxxxxxxxx"
FEISHU_APP_SECRET=""
# 卡片回调验签
FEISHU_VERIFICATION_TOKEN=""
# 启用加密时填
FEISHU_ENCRYPT_KEY=""
FEISHU_REDIRECT_URI="http://localhost:3000/api/auth/callback/feishu"

# === Vercel Blob（文件存储；M9 才用） ===
# vercel_blob_rw_*
BLOB_READ_WRITE_TOKEN=""

# === 限流（v2 接 Upstash Redis；当前内存版） ===
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# === 定时任务鉴权（飞书日报/周报） ===
# 由 systemd timer / crontab 触发 /api/cron/briefing/{daily|weekly}
# 时携带 Authorization: Bearer ${CRON_SECRET}
# 生成：openssl rand -hex 32
CRON_SECRET=""
